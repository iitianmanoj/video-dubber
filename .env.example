# Copy this file to `.env` and fill in what you need.
# Every value below is optional — the pipeline runs with zero config using
# Google Translate (via deep-translator) and Edge TTS, both keyless.

# Whisper model overrides
WHISPER_MODEL_GPU=large-v3
WHISPER_MODEL_CPU=medium

# Translation backend: google | nllb | indictrans2 | auto
TRANSLATION_ENGINE=google

# Speaker diarization (needs a free Hugging Face token with access to
# pyannote/speaker-diarization-3.1 accepted on huggingface.co)
ENABLE_DIARIZATION=true
HUGGINGFACE_TOKEN=

# Voice cloning via Coqui XTTS (GPU required)
ENABLE_VOICE_CLONE=false
